# Habuild Onboarding Platform - Environment Configuration
# Copy this file to .env and fill in your values

# Flask secret key (for session encryption)
# Generate a strong secret key for production
SECRET_KEY=your-secret-key-here

# Database connection URL
# Leave blank to use SQLite locally (no configuration needed)
# For local development:
#   DATABASE_URL=
# For production with AWS RDS PostgreSQL:
#   DATABASE_URL=postgresql://username:password@your-rds-endpoint.us-east-1.rds.amazonaws.com:5432/habuild
DATABASE_URL=
